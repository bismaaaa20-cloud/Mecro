for i, key in ipairs(allKeys) do
    local pct = (_G.MacroState[key] - 1) / (40 - 1)
    allSliders[i].Position = UDim2.new(pct, -6, 0, -4)
    allLabels[i].Text = "Jeda " .. allNames[i] .. ": " .. string.format("%.1f", _G.MacroState[key]) .. " Detik"
end
-- =================================================================
-- BAGIAN 3: SISTEM UTAMA LOOPING SERANGAN & KLIK SANGAT POJOK
-- =================================================================

local function kirimInputKeyPC(keyCode)
    _G.VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    task.wait(0.05)
    _G.VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
end

-- Thread Pengatur Siklus Pengeluaran Skill
task.spawn(function()
    while true do
        pcall(function()
            if _G.Player.Character and _G.Player.Character:FindFirstChild("Humanoid") and _G.Player.Character.Humanoid.Health > 0 then
                -- Menjalankan antrian skill bergantian berdasarkan nilai data slider-nya masing-masing [I]
                if _G.MacroState.Z then kirimInputKeyPC(Enum.KeyCode.Z) task.wait(_G.MacroState.DelayZ) end
                if _G.MacroState.X then kirimInputKeyPC(Enum.KeyCode.X) task.wait(_G.MacroState.DelayX) end
                if _G.MacroState.C then kirimInputKeyPC(Enum.KeyCode.C) task.wait(_G.MacroState.DelayC) end
                if _G.MacroState.V then kirimInputKeyPC(Enum.KeyCode.V) task.wait(_G.MacroState.DelayV) end
                if _G.MacroState.F then kirimInputKeyPC(Enum.KeyCode.F) task.wait(_G.MacroState.DelayF) end
            end
        end)
        task.wait(0.1)
    end
end)

-- Thread Pengatur Pukulan Cepat (M1) di Sudut Piksel Paling Pojok Kiri Atas (0,0)
task.spawn(function()
    while true do
        pcall(function()
            if _G.MacroState.AutoM1 and _G.Player.Character and _G.Player.Character.Humanoid.Health > 0 then
                -- Target koordinat 2% mepet ujung layar atas dekat tombol keluar Roblox
                local pojokX = _G.Camera.ViewportSize.X * 0.02
                local pojokY = _G.Camera.ViewportSize.Y * 0.02
                
                _G.VirtualInputManager:SendMouseButtonEvent(pojokX, pojokY, 0, true, game, 1)
                task.wait(0.02)
                _G.VirtualInputManager:SendMouseButtonEvent(pojokX, pojokY, 0, false, game, 1)
            end
        end)
        task.wait(0.15) -- Kecepatan pukulan dasar Buddha
    end
end)

