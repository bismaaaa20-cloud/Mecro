-- BAGIAN 3: LOGIKA TAHAN TOMBOL SKILL (HOLD MECHANISM) & M1 POJOK
-- =================================================================

local function tahanDanLepasKey(keyCode, durasiTahan)
    -- Mulai Tahan Tombol Keyboard Internal
    _G.VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    
    -- Ditahan sesuai durasi detik yang kamu atur pada Slider UI [I]
    task.wait(durasiTahan)
    
    -- Lepaskan Tombol Keyboard
    _G.VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    task.wait(0.1) 
end

-- Thread Pengatur Siklus Pengeluaran Skill
task.spawn(function()
    while true do
        pcall(function()
            if _G.Player.Character and _G.Player.Character:FindFirstChild("Humanoid") and _G.Player.Character.Humanoid.Health > 0 then
                
                if _G.MacroState.Z then tahanDanLepasKey(Enum.KeyCode.Z, _G.MacroState.HoldZ) end
                if _G.MacroState.X then tahanDanLepasKey(Enum.KeyCode.X, _G.MacroState.HoldX) end
                if _G.MacroState.C then tahanDanLepasKey(Enum.KeyCode.C, _G.MacroState.HoldC) end
                if _G.MacroState.V then tahanDanLepasKey(Enum.KeyCode.V, _G.MacroState.HoldV) end
                if _G.MacroState.F then tahanDanLepasKey(Enum.KeyCode.F, _G.MacroState.HoldF) end
                
            end
        end)
        task.wait(0.1) 
    end
end)

-- Thread Pengatur Pukulan Cepat (M1) di Sudut Piksel Paling Pojok Kiri Atas (0,0)
task.spawn(function()
    while true do
        pcall(function()
            if _G.MacroState.AutoM1 and _G.Player.Character and _G.Player.Character.Humanoid.Health > 0 then
                local pojokX = _G.Camera.ViewportSize.X * 0.02
                local pojokY = _G.Camera.ViewportSize.Y * 0.02
                
                _G.VirtualInputManager:SendMouseButtonEvent(pojokX, pojokY, 0, true, game, 1)
                task.wait(0.02)
                _G.VirtualInputManager:SendMouseButtonEvent(pojokX, pojokY, 0, false, game, 1)
            end
        end)
        task.wait(0.15)
    end
end)
