currentY = currentY + 35

local allSliders, allLabels, allNames, allKeys = {}, {}, {}, {}
local upZ = _G.buatKomponenSkill("Z", "Z", "DelayZ", allSliders, allLabels, allNames, allKeys)
local upX = _G.buatKomponenSkill("X", "X", "DelayX", allSliders, allLabels, allNames, allKeys)
local upC = _G.buatKomponenSkill("C", "C", "DelayC", allSliders, allLabels, allNames, allKeys)
local upV = _G.buatKomponenSkill("V", "V", "DelayV", allSliders, allLabels, allNames, allKeys)
local upF = _G.buatKomponenSkill("F", "F", "DelayF", allSliders, allLabels, allNames, allKeys)
local allUpdates = {upZ, upX, upC, upV, upF}

local BtnOn = Instance.new("TextButton")
