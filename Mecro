-- Fungsi Pembantu Komponen di dalam Scroll
local currentY = 5
_G.buatKomponenSkill = function(labelSkill, keyAktif, keyHold, allSliders, allLabels, allNames, allKeys)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0, 205, 0, 26)
    Btn.Position = UDim2.new(0, 5, 0, currentY)
    Btn.Font = Enum.Font.SourceSansBold
    Btn.TextSize = 12
    Btn.Parent = ScrollContainer
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 5)

    local function updateVisualTombol()
        if _G.MacroState[keyAktif] then
            Btn.Text = "Skill " .. labelSkill .. " : ON"
            Btn.BackgroundColor3 = Color3.fromRGB(40, 120, 40)
            Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            Btn.Text = "Skill " .. labelSkill .. " : OFF"
            Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
            Btn.TextColor3 = Color3.fromRGB(180, 180, 180)
        end
    end
    updateVisualTombol()

    Btn.MouseButton1Click:Connect(function()
        _G.MacroState[keyAktif] = not _G.MacroState[keyAktif]
        updateVisualTombol()
        _G.simpanSetelanKeHP()
    end)

    local SliderFrame = Instance.new("Frame")
    SliderFrame.Size = UDim2.new(0, 205, 0, 30)
    SliderFrame.Position = UDim2.new(0, 5, 0, currentY + 28)
    SliderFrame.BackgroundTransparency = 1
    SliderFrame.Parent = ScrollContainer

    local SliderLabel = Instance.new("TextLabel")
    SliderLabel.Size = UDim2.new(1, 0, 0, 14)
    SliderLabel.Text = "Durasi Tahan " .. labelSkill .. ": " .. string.format("%.1f", _G.MacroState[keyHold]) .. " Detik"
    SliderLabel.TextColor3 = Color3.fromRGB(180, 180, 190)
    SliderLabel.BackgroundTransparency = 1
    SliderLabel.TextXAlignment = Enum.TextXAlignment.Left
    SliderLabel.Font = Enum.Font.SourceSans
    SliderLabel.TextSize = 11
    SliderLabel.Parent = SliderFrame

    local SliderTrack = Instance.new("Frame")
    SliderTrack.Size = UDim2.new(1, 0, 0, 4)
    SliderTrack.Position = UDim2.new(0, 0, 0, 18)
    SliderTrack.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    SliderTrack.BorderSizePixel = 0
    SliderTrack.Parent = SliderFrame
    Instance.new("UICorner", SliderTrack).CornerRadius = UDim.new(0, 2)

    local SliderButton = Instance.new("TextButton")
    SliderButton.Size = UDim2.new(0, 12, 0, 12)
    SliderButton.Position = UDim2.new((_G.MacroState[keyHold] - 1) / (40 - 1), -6, 0, -4)
    SliderButton.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    SliderButton.Text = ""
    SliderButton.Parent = SliderTrack
    Instance.new("UICorner", SliderButton).CornerRadius = UDim.new(1, 0)

    local geser_aktif = false
    SliderButton.MouseButton1Down:Connect(function() geser_aktif = true end)
    _G.UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then geser_aktif = false end end)

    _G.UserInputService.InputChanged:Connect(function(input)
        if geser_aktif and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local posisiRelatifX = input.Position.X - SliderTrack.AbsolutePosition.X
            local persentase = math.clamp(posisiRelatifX / SliderTrack.AbsoluteSize.X, 0, 1)
            local hasilWaktu = 1 + (persentase * (40 - 1))
            hasilWaktu = math.round(hasilWaktu * 10) / 10
            
            _G.MacroState[keyHold] = hasilWaktu
            SliderButton.Position = UDim2.new(persentase, -6, 0, -4)
            SliderLabel.Text = "Durasi Tahan " .. labelSkill .. ": " .. string.format("%.1f", _G.MacroState[keyHold]) .. " Detik"
            _G.simpanSetelanKeHP()
        end
    end)

    table.insert(allSliders, SliderButton)
    table.insert(allLabels, SliderLabel)
    table.insert(allNames, labelSkill)
    table.insert(allKeys, keyHold)

    currentY = currentY + 62
    return updateVisualTombol
end

