_G.allUpdates = {}
_G.listSkillName = {"Z", "X", "C", "V", "F"}

_G.buatKomponenSkill = function(name, idx)
    local curY = 38 + ((idx - 1) * 64)
    local kAct, kHold = name, "Hold" .. name

    local Btn = Instance.new("TextButton", _G.Scroll)
    Btn.Size, Btn.Position = UDim2.new(0, 210, 0, 28), UDim2.new(0, 5, 0, curY)
    Btn.Font, Btn.TextSize = Enum.Font.SourceSansBold, 12
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)

    local function updateVisual()
        Btn.Text = _G.MacroState[kAct] and "Skill " .. name .. " : ACTIVE (ON)" or "Skill " .. name .. " : DISABLED (OFF)"
        Btn.BackgroundColor3 = _G.MacroState[kAct] and Color3.fromRGB(30, 140, 60) or Color3.fromRGB(40, 40, 50)
        Btn.TextColor3 = _G.MacroState[kAct] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(170, 170, 170)
    end
    updateVisual()
    table.insert(_G.allUpdates, updateVisual)

    Btn.MouseButton1Click:Connect(function() _G.MacroState[kAct] = not _G.MacroState[kAct] updateVisual() _G.simpanSetelanKeHP() end)

    local SFrame = Instance.new("Frame", _G.Scroll)
    SFrame.Size, SFrame.Position, SFrame.BackgroundTransparency = UDim2.new(0, 210, 0, 30), UDim2.new(0, 5, 0, curY + 30), 1

    local SLabel = Instance.new("TextLabel", SFrame)
    SLabel.Size, SLabel.BackgroundTransparency, SLabel.TextXAlignment = UDim2.new(1, 0, 0, 14), 1, Enum.TextXAlignment.Left
    SLabel.TextColor3, SLabel.Font, SLabel.TextSize = Color3.fromRGB(190, 190, 200), Enum.Font.SourceSans, 11

    local STrack = Instance.new("Frame", SFrame)
    STrack.Size, STrack.Position, STrack.BackgroundColor3, STrack.BorderSizePixel = UDim2.new(1, 0, 0, 5), UDim2.new(0, 0, 0, 18), Color3.fromRGB(45, 45, 55), 0
    Instance.new("UICorner", STrack).CornerRadius = UDim.new(0, 3)

    local SBtn = Instance.new("TextButton", STrack)
    SBtn.Size, SBtn.BackgroundColor3, SBtn.Text = UDim2.new(0, 14, 0, 14), Color3.fromRGB(0, 150, 255), ""
    Instance.new("UICorner", SBtn).CornerRadius = UDim.new(1, 0)

    local function refreshSlider()
        local pct = (_G.MacroState[kHold] - 1) / (40 - 1)
        SBtn.Position = UDim2.new(pct, -7, 0, -5)
        SLabel.Text = "Durasi Tahan [" .. name .. "]: " .. string.format("%.1f", _G.MacroState[kHold]) .. " Detik"
    end
    refreshSlider()

    -- Saklar lokal mandiri pengunci tarikan geser luar/jalur track slider saja
    local isDragging = false
    SBtn.MouseButton1Down:Connect(function() isDragging = true end)
    _G.UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then isDragging = false end end)

    _G.UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local pct = math.clamp((input.Position.X - STrack.AbsolutePosition.X) / STrack.AbsoluteSize.X, 0, 1)
            _G.MacroState[kHold] = math.round((1 + (pct * 39)) * 10) / 10
            refreshSlider()
            _G.simpanSetelanKeHP()
        end
    end)
end

-- Menjalankan duplikasi otomatis untuk melahirkan seluruh tombol + slider
for idx, name in ipairs(_G.listSkillName) do _G.buatKomponenSkill(name, idx) end
