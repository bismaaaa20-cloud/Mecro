_G.NamaFileConfig = "MacroConfig_BloxFruits_HybridV3.json"

-- Mengunci metatable Roblox agar bisa memanipulasi deteksi perangkat secara dinamis
local metatable = getrawmetatable(game)
if setreadonly then setreadonly(metatable, false) elseif make_writeable then make_writeable(metatable, false) end
local oldIndex = metatable.__index

metatable.__index = newcclosure(function(self, key)
    if self == _G.UserInputService then
        -- Mengecek apakah ada tombol makro yang sedang aktif menyala
        local adaMakroAktif = _G.MacroState.AutoM1 or _G.MacroState.Z or _G.MacroState.X or _G.MacroState.C or _G.MacroState.V or _G.MacroState.F
        
        if adaMakroAktif then
            -- Jika ada makro menyala, paksa game membaca input Komputer (PC)
            if key == "KeyboardEnabled" or key == "MouseEnabled" then return true
            elseif key == "TouchEnabled" then return false end
        else
            -- Jika semua saklar mati, kembalikan ke mode HP / Mobile total agar analog muncul
            if key == "KeyboardEnabled" or key == "MouseEnabled" then return false
            elseif key == "TouchEnabled" then return true end
        end
    end
    return oldIndex(self, key)
end)

-- Tabel pencatatan data status tombol dan durasi tahan
_G.MacroState = {
    AutoM1 = false,
    Z = false, X = false, C = false, V = false, F = false,
    HoldZ = 1.0, HoldX = 1.0, HoldC = 1.0, HoldV = 1.0, HoldF = 1.0
}

_G.simpanSetelanKeHP = function()
    pcall(function()
        if writefile then
            writefile(_G.NamaFileConfig, _G.HttpService:JSONEncode(_G.MacroState))
        end
    end)
end

_G.muatSetelanDariHP = function()
    pcall(function()
        if isfile and readfile and isfile(_G.NamaFileConfig) then
            local dataTabel = _G.HttpService:JSONDecode(readfile(_G.NamaFileConfig))
            if dataTabel then
                for key, value in pairs(dataTabel) do
                    if _G.MacroState[key] ~= nil then _G.MacroState[key] = value end
                end
            end
        end
    end)
end
_G.muatSetelanDariHP()
