-- BAGIAN 1: PC SPOOFING & AUTO SAVE DATA SYSTEM
-- =================================================================

_G.UserInputService = game:GetService("UserInputService")
_G.VirtualInputManager = game:GetService("VirtualInputManager")
_G.HttpService = game:GetService("HttpService")
_G.Camera = workspace.CurrentCamera
_G.Player = game.Players.LocalPlayer
_G.CoreGui = game:GetService("CoreGui")

_G.NamaFileConfig = "MacroConfig_BloxFruits_MultiSlider.json"

-- 1. PC SPOOFING (Mengelabui Roblox agar membuka fitur Input Key PC)
local metatable = getrawmetatable(game)
if setreadonly then setreadonly(metatable, false) elseif make_writeable then make_writeable(metatable, false) end
local oldIndex = metatable.__index
metatable.__index = newcclosure(function(self, key)
    if self == _G.UserInputService then
        if key == "KeyboardEnabled" or key == "MouseEnabled" then return true
        elseif key == "TouchEnabled" then return false end
    end
    return oldIndex(self, key)
end)

-- 2. TENTUKAN VARIABEL SETELAN (STATE)
_G.MacroState = {
    AutoM1 = false,
    Z = false, X = false, C = false, V = false, F = false,
    DelayZ = 2.0, DelayX = 2.0, DelayC = 2.0, DelayV = 2.0, DelayF = 2.0
}

-- 3. FUNGSI SIMPAN & MUAT DATA DARI HP
_G.simpanSetelanKeHP = function()
    pcall(function()
        if writefile then
            local dataTeks = _G.HttpService:JSONEncode(_G.MacroState)
            writefile(_G.NamaFileConfig, dataTeks)
        end
    end)
end

_G.muatSetelanDariHP = function()
    pcall(function()
        if isfile and readfile and isfile(_G.NamaFileConfig) then
            local dataTeks = readfile(_G.NamaFileConfig)
            local dataTabel = _G.HttpService:JSONDecode(dataTeks)
            if dataTabel then
                for key, value in pairs(dataTabel) do
                    if _G.MacroState[key] ~= nil then _G.MacroState[key] = value end
                end
            end
        end
    end)
end

_G.muatSetelanDariHP()
